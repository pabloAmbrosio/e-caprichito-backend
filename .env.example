# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Environment
NODE_ENV="development"

# CORS
FRONTEND_URL="http://localhost:5173"

# JWT
JWT_SECRET=""
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Cookie
COOKIE_SECRET=""

# OAuth Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="/api/auth/google/callback"

# SMS / Messaging
# Valores válidos: "log" (dev), "twilio" (SMS + WhatsApp), "whatsapp" (solo WhatsApp)
SMS_MODE="log"

# Twilio (solo si SMS_MODE != "log")
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Rate limiting
RATE_LIMIT_MAX="500"
RATE_LIMIT_WINDOW="60000"

# Server
PORT=3000

# Promotions
PROMOTION_GRACE_PERIOD_MINUTES="10"

# Order Expiration
ORDER_EXPIRATION_MINUTES="30"
ORDER_CRON_INTERVAL="*/1 * * * *"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_URL="redis://:password@localhost:6379"

# Cloudinary (signed uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Seed
SEED_BASE_URL="http://localhost:3000"
