        {
          "name": "Crear Orden desde Carrito",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    if (response.success && response.data) {",
                  "        pm.collectionVariables.set('orderId', response.data.id);",
                  "        ",
                  "        // Agregar a lista de órdenes",
                  "        let lista = JSON.parse(pm.collectionVariables.get('ordersList') || '[]');",
                  "        lista.push(response.data);",
                  "        pm.collectionVariables.set('ordersList', JSON.stringify(lista));",
                  "        ",
                  "        pm.test('✅ Orden creada exitosamente', () => {",
                  "            pm.expect(response.data).to.have.property('id');",
                  "            pm.expect(response.data).to.have.property('status');",
                  "            pm.expect(response.data.items).to.be.an('array');",
                  "        });",
                  "        ",
                  "        console.log(`🛍️ Orden creada: ${response.data.id}`);",
                  "        console.log(`📊 Estado: ${response.data.status}`);",
                  "        console.log(`📦 ${response.data.items.length} items en la orden`);",
                  "        console.log('\\n📋 Items:');",
                  "        response.data.items.forEach((item, i) => {",
                  "            console.log(`   ${i + 1}. ${item.product.title} x${item.quantity}`);",
                  "        });",
                  "        console.log('\\n🛒 Carrito vaciado y listo para nuevas compras');",
                  "    }",
                  "} else if (pm.response.code === 400) {",
                  "    const response = pm.response.json();",
                  "    pm.test('❌ Error al crear orden', () => {",
                  "        pm.response.to.have.status(400);",
                  "    });",
                  "    console.log(`⚠️ ${response.msg}`);",
                  "    ",
                  "    if (response.msg.includes('vacio')) {",
                  "        console.log('💡 Agrega productos al carrito primero');",
                  "    } else if (response.msg.includes('stock')) {",
                  "        console.log('💡 Actualiza el inventario del producto');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
