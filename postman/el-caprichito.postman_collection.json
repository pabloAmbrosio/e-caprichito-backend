              "raw": "{{baseUrl}}/api/order/{{orderId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "order", "{{orderId}}", "cancel"]
            },
            "description": "Cancela una orden en estado PENDING y libera el stock reservado."
          }
        }
      ]
