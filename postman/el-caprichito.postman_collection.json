                  "    if (response.success && response.data) {",
                  "        pm.collectionVariables.set('ordersList', JSON.stringify(response.data));",
                  "        ",
                  "        pm.test('✅ Órdenes obtenidas', () => {",
                  "            pm.expect(response.data).to.be.an('array');",
                  "        });",
