    {
      "name": "📦 Productos",
      "item": [
        {
          "name": "Listar Todos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('✅ Lista de productos obtenida', () => {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(response).to.be.an('array');",
                  "});",
                  "",
                  "// Guardar lista completa de productos",
                  "pm.collectionVariables.set('productsList', JSON.stringify(response));",
                  "console.log(`📦 ${response.length} productos encontrados`);",
                  "",
                  "// Guardar el primer producto como activo",
                  "if (response.length > 0) {",
                  "    pm.collectionVariables.set('productId', response[0].id);",
                  "    pm.collectionVariables.set('productTitle', response[0].title);",
                  "    pm.collectionVariables.set('lastProductIndex', '0');",
                  "    console.log(`🎯 Producto activo: ${response[0].title} (${response[0].id})`);",
                  "}",
                  "",
                  "// Mostrar todos los productos",
                  "response.forEach((p, i) => {",
                  "    console.log(`   ${i}: ${p.title}`);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "Obtener por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('productId', response.id);",
                  "    pm.collectionVariables.set('productTitle', response.title);",
                  "    ",
                  "    pm.test('✅ Producto encontrado', () => {",
                  "        pm.expect(response).to.have.property('id');",
                  "        pm.expect(response).to.have.property('title');",
                  "    });",
                  "    console.log(`📦 ${response.title}`);",
                  "} else if (pm.response.code === 404) {",
                  "    pm.test('❌ Producto no encontrado', () => {",
                  "        pm.response.to.have.status(404);",
                  "    });",
                  "} else if (pm.response.code === 400) {",
                  "    pm.test('❌ ID inválido', () => {",
                  "        pm.expect(pm.response.json().error).to.include('UUID');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Crear Producto",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const productos = ['Camiseta', 'Pantalón', 'Zapatos', 'Gorra', 'Reloj', 'Bolso', 'Collar', 'Pulsera', 'Bufanda', 'Cinturón'];",
                  "const adjetivos = ['Elegante', 'Casual', 'Deportivo', 'Vintage', 'Moderno', 'Clásico', 'Premium', 'Exclusivo'];",
                  "const colores = ['Negro', 'Blanco', 'Azul', 'Rojo', 'Verde', 'Dorado', 'Plateado'];",
                  "",
                  "const producto = productos[Math.floor(Math.random() * productos.length)];",
                  "const adjetivo = adjetivos[Math.floor(Math.random() * adjetivos.length)];",
                  "const color = colores[Math.floor(Math.random() * colores.length)];",
                  "",
                  "pm.variables.set('randomProductTitle', `${producto} ${adjetivo} ${color}`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    // Guardar como producto activo",
                  "    pm.collectionVariables.set('productId', response.id);",
                  "    pm.collectionVariables.set('productTitle', response.title);",
                  "    ",
                  "    // Agregar a la lista",
                  "    let lista = JSON.parse(pm.collectionVariables.get('productsList') || '[]');",
                  "    lista.push(response);",
                  "    pm.collectionVariables.set('productsList', JSON.stringify(lista));",
                  "    ",
                  "    pm.test('✅ Producto creado', () => {",
                  "        pm.expect(response).to.have.property('id');",
                  "        pm.expect(response).to.have.property('title');",
                  "    });",
                  "    console.log(`📦 Creado: ${response.title}`);",
                  "    console.log(`🎯 ID: ${response.id}`);",
                  "} else if (pm.response.code === 401) {",
                  "    pm.test('🔒 No autorizado - obtén un token primero', () => {",
                  "        pm.response.to.have.status(401);",
                  "    });",
                  "} else if (pm.response.code === 400) {",
                  "    pm.test('❌ Error de validación', () => {",
                  "        pm.response.to.have.status(400);",
                  "    });",
                  "    console.log('Error:', pm.response.json().error);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"{{randomProductTitle}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "Actualizar Producto",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Usa el título actual y le agrega 'Actualizado'",
                  "const currentTitle = pm.collectionVariables.get('productTitle') || 'Producto';",
                  "pm.variables.set('updatedTitle', `${currentTitle} (Actualizado)`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('productTitle', response.title);",
                  "    ",
                  "    pm.test('✅ Producto actualizado', () => {",
                  "        pm.expect(response.title).to.include('Actualizado');",
                  "    });",
                  "    console.log(`📝 Nuevo título: ${response.title}`);",
                  "} else if (pm.response.code === 404) {",
                  "    pm.test('❌ Producto no encontrado', () => {",
                  "        pm.response.to.have.status(404);",
                  "    });",
                  "    console.log('⚠️ Ejecuta \"Listar Todos\" primero');",
                  "} else if (pm.response.code === 401) {",
                  "    pm.test('🔒 No autorizado', () => {",
                  "        pm.response.to.have.status(401);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"{{updatedTitle}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Eliminar Producto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 204) {",
                  "    // Remover de la lista local",
                  "    let lista = JSON.parse(pm.collectionVariables.get('productsList') || '[]');",
                  "    const deletedId = pm.collectionVariables.get('productId');",
                  "    lista = lista.filter(p => p.id !== deletedId);",
                  "    pm.collectionVariables.set('productsList', JSON.stringify(lista));",
                  "    ",
                  "    // Seleccionar siguiente producto si existe",
                  "    if (lista.length > 0) {",
                  "        pm.collectionVariables.set('productId', lista[0].id);",
                  "        pm.collectionVariables.set('productTitle', lista[0].title);",
                  "        console.log(`🎯 Nuevo producto activo: ${lista[0].title}`);",
                  "    }",
                  "    ",
                  "    pm.test('✅ Producto eliminado (soft delete)', () => {",
                  "        pm.response.to.have.status(204);",
                  "    });",
                  "    console.log('🗑️ Producto eliminado');",
                  "} else if (pm.response.code === 404) {",
                  "    pm.test('❌ Producto no encontrado', () => {",
                  "        pm.response.to.have.status(404);",
                  "    });",
                  "} else if (pm.response.code === 401) {",
                  "    pm.test('🔒 No autorizado', () => {",
                  "        pm.response.to.have.status(401);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          }
        },
        {
          "name": "🔄 Seleccionar Producto Aleatorio",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const lista = JSON.parse(pm.collectionVariables.get('productsList') || '[]');",
                  "",
                  "if (lista.length > 0) {",
                  "    const randomIndex = Math.floor(Math.random() * lista.length);",
                  "    const producto = lista[randomIndex];",
                  "    ",
                  "    pm.collectionVariables.set('productId', producto.id);",
                  "    pm.collectionVariables.set('productTitle', producto.title);",
                  "    pm.collectionVariables.set('lastProductIndex', randomIndex.toString());",
                  "    ",
                  "    console.log(`🎲 Seleccionado: ${producto.title}`);",
                  "    console.log(`📍 Índice: ${randomIndex} de ${lista.length}`);",
                  "} else {",
                  "    console.log('⚠️ Lista vacía. Ejecuta \"Listar Todos\" primero');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Este request no hace llamada HTTP, solo selecciona",
                  "pm.test('✅ Producto seleccionado', () => {",
                  "    const productId = pm.collectionVariables.get('productId');",
                  "    pm.expect(productId).to.not.be.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "🛒 Carrito",
      "item": [
        {
          "name": "Ver Carrito",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    pm.collectionVariables.set('cartId', response.id);",
                  "    pm.collectionVariables.set('cartItemsList', JSON.stringify(response.items));",
                  "    ",
                  "    pm.test('✅ Carrito obtenido', () => {",
                  "        pm.expect(response).to.have.property('items');",
                  "        pm.expect(response.items).to.be.an('array');",
                  "    });",
                  "    ",
                  "    console.log(`🛒 Carrito ID: ${response.id}`);",
                  "    console.log(`📦 ${response.items.length} items en el carrito`);",
                  "    ",
                  "    // Guardar primer item como activo",
                  "    if (response.items.length > 0) {",
                  "        pm.collectionVariables.set('cartItemId', response.items[0].id);",
                  "        console.log('\\n📋 Items:');",
                  "        response.items.forEach((item, i) => {",
                  "            console.log(`   ${i}: ${item.product.title} x${item.quantity} (${item.id})`);",
                  "        });",
                  "    }",
                  "} else if (pm.response.code === 401) {",
                  "    pm.test('🔒 No autorizado', () => {",
                  "        pm.response.to.have.status(401);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": ["{{baseUrl}}"],
              "path": ["cart"]
            }
          }
        },
        {
          "name": "Agregar al Carrito",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Genera cantidad aleatoria entre 1 y 5",
                  "pm.variables.set('randomQuantity', Math.floor(Math.random() * 5) + 1);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    pm.collectionVariables.set('cartItemId', response.id);",
                  "    ",
                  "    // Agregar a lista local",
                  "    let lista = JSON.parse(pm.collectionVariables.get('cartItemsList') || '[]');",
                  "    const existingIndex = lista.findIndex(i => i.id === response.id);",
                  "    if (existingIndex >= 0) {",
                  "        lista[existingIndex] = response;",
                  "    } else {",
                  "        lista.push(response);",
                  "    }",
                  "    pm.collectionVariables.set('cartItemsList', JSON.stringify(lista));",
                  "    ",
                  "    pm.test('✅ Producto agregado al carrito', () => {",
                  "        pm.expect(response).to.have.property('id');",
                  "        pm.expect(response).to.have.property('quantity');",
                  "    });",
                  "    console.log(`➕ ${response.product.title} x${response.quantity}`);",
                  "} else if (pm.response.code === 404) {",
                  "    pm.test('❌ Producto no encontrado', () => {",
                  "        pm.response.to.have.status(404);",
                  "    });",
                  "    console.log('⚠️ Ejecuta \"Listar Productos\" y selecciona uno');",
                  "} else if (pm.response.code === 400) {",
                  "    pm.test('❌ Error de validación', () => {",
                  "        pm.response.to.have.status(400);",
                  "    });",
                  "    console.log('Error:', pm.response.json().error);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"productId\": \"{{productId}}\",\n    \"quantity\": {{randomQuantity}}\n}"
            },
