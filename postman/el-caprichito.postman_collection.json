      "script": {
        "type": "text/javascript",
        "exec": [
          "// Helpers globales disponibles en toda la colección",
          "pm.globals.set('getRandomFromArray', function(arr) {",
          "    return arr[Math.floor(Math.random() * arr.length)];",
          "});"
        ]
      }
    }
