    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Obtener Token (Dev)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (pm.response.code === 200 && response.token) {",
                  "    pm.collectionVariables.set('token', response.token);",
                  "    pm.collectionVariables.set('userId', response.user.id);",
                  "    pm.collectionVariables.set('userRole', response.user.role);",
                  "    ",
                  "    console.log('🔑 Token guardado');",
                  "    console.log('👤 Usuario:', response.user.email);",
                  "    console.log('🎭 Rol:', response.user.role);",
                  "    ",
                  "    pm.test('✅ Token obtenido correctamente', () => {",
                  "        pm.expect(response.token).to.be.a('string');",
                  "        pm.expect(response.user).to.have.property('id');",
                  "        pm.expect(response.user).to.have.property('role');",
                  "    });",
                  "} else if (pm.response.code === 404) {",
                  "    pm.test('❌ Usuario no encontrado', () => {",
                  "        pm.expect(response.error).to.equal('Usuario no encontrado');",
                  "    });",
                  "    console.log('⚠️ Usuario no existe. Usa uno del seed:');",
                  "    console.log('   - admin@caprichito.com');",
                  "    console.log('   - customer@caprichito.com');",
                  "} else if (pm.response.code === 400) {",
                  "    pm.test('❌ Email inválido', () => {",
                  "        pm.expect(response.error).to.include('correo');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{userEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/dev/token",
              "host": ["{{baseUrl}}"],
              "path": ["dev", "token"]
            }
          }
        },
