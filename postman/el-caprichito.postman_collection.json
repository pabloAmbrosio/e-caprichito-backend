    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "userRole",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "productTitle",
      "value": ""
    },
    {
      "key": "productsList",
      "value": "[]"
    },
    {
      "key": "cartId",
      "value": ""
    },
    {
      "key": "cartItemId",
      "value": ""
    },
    {
      "key": "cartItemsList",
