              "raw": "{{baseUrl}}/api/order",
              "host": ["{{baseUrl}}"],
              "path": ["api", "order"]
            }
          }
        },
        {
          "name": "Cancelar Orden",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    if (response.success && response.data) {",
                  "        pm.test('✅ Orden cancelada', () => {",
                  "            pm.expect(response.data.status).to.equal('CANCELLED');",
                  "        });",
                  "        ",
                  "        console.log(`🛍️ Orden cancelada: ${response.data.id}`);",
                  "        console.log(`📊 Estado: ${response.data.status}`);",
                  "        console.log('🔓 Stock liberado y devuelto al inventario');",
                  "        ",
                  "        // Actualizar lista local",
                  "        let lista = JSON.parse(pm.collectionVariables.get('ordersList') || '[]');",
                  "        const index = lista.findIndex(o => o.id === response.data.id);",
                  "        if (index >= 0) lista[index] = response.data;",
                  "        pm.collectionVariables.set('ordersList', JSON.stringify(lista));",
                  "    }",
                  "} else if (pm.response.code === 400) {",
                  "    const response = pm.response.json();",
                  "    pm.test('❌ No se puede cancelar', () => {",
                  "        pm.response.to.have.status(400);",
                  "    });",
                  "    console.log(`⚠️ ${response.msg}`);",
                  "    ",
                  "    if (response.msg.includes('PENDING')) {",
                  "        console.log('💡 Solo se pueden cancelar órdenes en estado PENDING');",
                  "    }",
                  "} else if (pm.response.code === 404) {",
                  "    pm.test('❌ Orden no encontrada', () => {",
                  "        pm.response.to.have.status(404);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
