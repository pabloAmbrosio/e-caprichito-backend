              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "request-otp"]
            },
            "description": "Re-envía el código OTP si expiró. Válido por 5 minutos."
          }
        },
        {
          "name": "Refresh Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (pm.response.code === 200 && response.success) {",
                  "    pm.collectionVariables.set('accessToken', response.data.accessToken);",
                  "    pm.collectionVariables.set('token', response.data.accessToken);",
                  "    ",
                  "    if (response.data.refreshToken) {",
                  "        pm.collectionVariables.set('refreshToken', response.data.refreshToken);",
                  "    }",
                  "    ",
                  "    pm.test('✅ Token renovado', () => {",
                  "        pm.expect(response.data.accessToken).to.be.a('string');",
                  "    });",
                  "    console.log('🔄 Access token renovado (válido 15 min)');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
