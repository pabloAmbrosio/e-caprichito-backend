    {
      "name": "🔐 Auth - Sistema Profesional",
      "item": [
        {
          "name": "1️⃣ Registro (Username + Phone + Password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (pm.response.code === 200 && response.success) {",
                  "    pm.collectionVariables.set('userId', response.data.userId);",
                  "    pm.collectionVariables.set('userPhone', response.data.phone);",
                  "    ",
                  "    pm.test('✅ Usuario registrado - revisa consola para OTP', () => {",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.data.userId).to.be.a('string');",
                  "    });",
                  "    ",
                  "    console.log('🎉 Usuario registrado exitosamente');",
                  "    console.log('📱 Revisa la consola del servidor para el código OTP');",
                  "    console.log(`👤 User ID: ${response.data.userId}`);",
                  "    console.log('➡️ Siguiente paso: Ejecuta \"Verificar Teléfono (OTP)\"');",
                  "} else if (pm.response.code === 400) {",
                  "    pm.test('❌ Error de validación', () => {",
                  "        pm.response.to.have.status(400);",
                  "    });",
                  "    console.log('Error:', response.msg);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"testuser\",\n    \"phone\": \"+15559876543\",\n    \"password\": \"Test123456\",\n    \"email\": \"test@example.com\",\n    \"firstName\": \"Test\",\n    \"lastName\": \"User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Registra un nuevo usuario. Requiere username único, teléfono (E.164), y password (8+ chars, 1 mayúscula, 1 minúscula, 1 número). Envía OTP al teléfono."
          }
        },
        {
          "name": "2️⃣ Verificar Teléfono (OTP)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (pm.response.code === 200 && response.success) {",
                  "    pm.collectionVariables.set('accessToken', response.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', response.data.refreshToken);",
                  "    pm.collectionVariables.set('token', response.data.accessToken);",
                  "    pm.collectionVariables.set('userId', response.data.user.id);",
                  "    pm.collectionVariables.set('username', response.data.user.username);",
                  "    pm.collectionVariables.set('userRole', response.data.user.role);",
                  "    ",
                  "    pm.test('✅ Teléfono verificado - tokens recibidos', () => {",
                  "        pm.expect(response.data.accessToken).to.be.a('string');",
                  "        pm.expect(response.data.refreshToken).to.be.a('string');",
                  "    });",
                  "    ",
                  "    console.log('🎉 Teléfono verificado exitosamente');",
                  "    console.log('🔑 Access token guardado (válido 15 min)');",
                  "    console.log('🔄 Refresh token guardado (válido 7 días)');",
                  "    console.log(`👤 Usuario: ${response.data.user.username} (${response.data.user.role})`);",
                  "} else if (pm.response.code === 400) {",
                  "    pm.test('❌ Código OTP inválido o expirado', () => {",
                  "        pm.response.to.have.status(400);",
                  "    });",
                  "    console.log('Error:', response.msg);",
                  "    console.log('💡 Usa \"Re-enviar OTP\" si expiró');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"userId\": \"{{userId}}\",\n    \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-phone",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify-phone"]
            },
            "description": "Verifica el teléfono con el código OTP de 6 dígitos. Retorna access token (15min) y refresh token (7 días)."
          }
        },
        {
          "name": "3️⃣ Login (Username/Email/Phone + Password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (pm.response.code === 200 && response.success) {",
                  "    pm.collectionVariables.set('accessToken', response.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', response.data.refreshToken);",
                  "    pm.collectionVariables.set('token', response.data.accessToken);",
                  "    pm.collectionVariables.set('userId', response.data.user.id);",
                  "    pm.collectionVariables.set('username', response.data.user.username);",
                  "    pm.collectionVariables.set('userRole', response.data.user.role);",
                  "    ",
                  "    pm.test('✅ Login exitoso', () => {",
                  "        pm.expect(response.data.accessToken).to.be.a('string');",
                  "    });",
                  "    ",
                  "    console.log('🔐 Login exitoso');",
                  "    console.log(`👤 Usuario: ${response.data.user.username}`);",
                  "    console.log(`🎭 Rol: ${response.data.user.role}`);",
                  "} else if (pm.response.code === 400) {",
                  "    const msg = response.msg || '';",
                  "    pm.test('❌ Error en login', () => {",
                  "        pm.response.to.have.status(400);",
                  "    });",
                  "    console.log('Error:', msg);",
                  "    ",
                  "    if (msg.includes('teléfono')) {",
                  "        console.log('💡 Verifica tu teléfono primero con el OTP');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"identifier\": \"customer\",\n    \"password\": \"Customer123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login con username, email o phone + password. El identifier puede ser cualquiera de los tres. Requiere teléfono verificado."
          }
        },
