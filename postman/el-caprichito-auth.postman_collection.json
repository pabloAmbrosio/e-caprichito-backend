        {
          "name": "Re-enviar OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (pm.response.code === 200 && response.success) {",
                  "    pm.test('✅ OTP enviado', () => {",
                  "        pm.expect(response.success).to.be.true;",
                  "    });",
                  "    console.log('📱 Nuevo código OTP enviado');",
                  "    console.log('📝 Revisa la consola del servidor para el código');",
                  "    console.log(`⏱️ Válido por ${response.data.expiresIn} segundos`);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
