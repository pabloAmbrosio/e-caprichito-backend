generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS: ROLES ───────────────────────────────────────────

enum AdminRole {
  OWNER    // Máximo control, puede realizar cualquier operación
  ADMIN    // Gestiona usuarios, productos, órdenes
  MANAGER  // Ver y editar, sin crear ni eliminar
  SELLER   // Gestiona sus propios productos y ventas
  CUSTOMER // Solo puede comprar (default)
}

enum CustomerRole {
  MEMBER     // Cliente básico
  VIP_FAN    // Nivel 1 VIP
  VIP_LOVER  // Nivel 2 VIP
  VIP_LEGEND // Nivel 3 VIP (máximo)
}

// ─── ENUMS: ÓRDENES Y ENTREGAS ──────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeliveryType {
  PICKUP
  HOME_DELIVERY
  SHIPPING
}

enum ShipmentStatus {
  PENDING
  PREPARING
  READY_FOR_PICKUP
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

// ─── ENUMS: PAGOS ───────────────────────────────────────────

enum PaymentStatus {
  PENDING
  AWAITING_REVIEW
  APPROVED
  REJECTED
  REFUNDED
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  MANUAL_TRANSFER
  CASH_ON_DELIVERY
}

// ─── ENUMS: MOTOR DE PROMOCIONES ────────────────────────────

enum RuleOperator {
  ALL // AND lógico
  ANY // OR lógico
}

enum RuleType {
  PRODUCT
  CATEGORY
  TAG
  CART_MIN_TOTAL
  CART_MIN_QUANTITY
  CUSTOMER_ROLE
  FIRST_PURCHASE
}

enum ComparisonOperator {
  EQUALS
  NOT_EQUALS
  IN
  NOT_IN
  GREATER_THAN
  LESS_THAN
  GREATER_OR_EQUAL
  LESS_OR_EQUAL
}

enum ActionType {
  PERCENTAGE_DISCOUNT
  FIXED_DISCOUNT
  BUY_X_GET_Y
}

enum ActionTarget {
  PRODUCT
  CART
  CHEAPEST_ITEM
}

// ─── ENUMS: PRODUCTOS ───────────────────────────────────────

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─── MODELO: USER ───────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  email        String?   @unique
  phone        String?   @unique
  passwordHash String?
  googleId     String?   @unique
  firstName    String?
  lastName     String?
  phoneVerified Boolean  @default(false)
  emailVerified Boolean  @default(false)
  adminRole    AdminRole    @default(CUSTOMER)
  customerRole CustomerRole?
  lastLoginAt  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Carrito activo (puntero maestro — un solo campo garantiza unicidad)
  activeCartId String? @unique
  activeCart   Cart?   @relation("ActiveCart", fields: [activeCartId], references: [id])

  // Relaciones
  addresses          Address[]
  allCarts           Cart[]
  orders             Order[]
  abstractProducts   AbstractProduct[]
  products           Product[]
  productLikes       ProductLike[]
  promotionUsages    PromotionUsage[]
  customerPayments   Payment[]  @relation("CustomerPayments")
  reviewedPayments   Payment[]  @relation("ReviewedPayments")
  auditChanges       OrderStatusAuditLog[] @relation("AuditChanges")
  shipmentEvents     ShipmentEvent[]       @relation("ShipmentEventStaff")
  otpCodes           OTPCode[]

  @@index([phone])
  @@index([email])
  @@index([username])
  @@index([adminRole])
}

// ─── MODELO: CATEGORY (jerárquica) ──────────────────────────

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  image       String?
  emoticon    String?

  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  abstractProducts AbstractProduct[]

  @@index([parentId])
  @@index([isActive])
}

// ─── MODELO: ABSTRACT PRODUCT (producto base) ───────────────

model AbstractProduct {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  description String        @db.Text
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  tags        String[]
  status       ProductStatus @default(DRAFT)
  isFeatured   Boolean       @default(false)
  publishedAt  DateTime?
  seoMetadata  Json?
  createdBy    String
  creator      User          @relation(fields: [createdBy], references: [id])
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  products     Product[]
  productLikes ProductLike[]

  @@index([categoryId])
  @@index([status])
  @@index([createdBy])
}

// ─── MODELO: PRODUCT (variante) ─────────────────────────────

model Product {
  id                    String        @id @default(uuid())
  abstractProductId     String
  abstractProduct       AbstractProduct @relation(fields: [abstractProductId], references: [id])
  title                 String
  sku                   String        @unique
  priceInCents          Int
  compareAtPriceInCents Int?
  details               Json
  images                Json?
  status                ProductStatus @default(DRAFT)
  createdBy             String
  creator               User          @relation(fields: [createdBy], references: [id])
  deletedAt             DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]
  inventory  Inventory?

  @@index([abstractProductId])
  @@index([status])
  @@index([createdBy])
}

// ─── MODELO: PRODUCT LIKE ───────────────────────────────────

model ProductLike {
  id                String          @id @default(uuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  abstractProductId String
  abstractProduct   AbstractProduct @relation(fields: [abstractProductId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())

  @@unique([userId, abstractProductId])
  @@index([abstractProductId])
  @@index([userId])
}

// ─── MODELO: CART ───────────────────────────────────────────

model Cart {
  id         String    @id @default(uuid())
  customerId String
  customer   User      @relation(fields: [customerId], references: [id])
  couponCode String?
  activeFor  User?     @relation("ActiveCart")
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  items CartItem[]

  @@index([customerId])
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
}

// ─── MODELO: INVENTORY ──────────────────────────────────────

model Inventory {
  id            String   @id @default(uuid())
  productId     String   @unique
  product       Product  @relation(fields: [productId], references: [id])
  physicalStock Int      @default(0)
  reservedStock Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── MODELO: ORDER ──────────────────────────────────────────

model Order {
  id                   String      @id @default(uuid())
  customerId           String
  customer             User        @relation(fields: [customerId], references: [id])
  status               OrderStatus @default(PENDING)
  discountTotalInCents Int?
  addressSnapshot      Json?
  expiresAt            DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  items           OrderItem[]
  promotionUsages PromotionUsage[]
  statusAuditLogs OrderStatusAuditLog[]
  payments        Payment[]
  shipment        Shipment?

  @@index([customerId])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orderId, productId])
}

// ─── MODELO: ORDER STATUS AUDIT LOG ─────────────────────────

model OrderStatusAuditLog {
  id             String      @id @default(uuid())
  orderId        String
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  previousStatus OrderStatus
  newStatus      OrderStatus
  changedBy      String
  changedByUser  User        @relation("AuditChanges", fields: [changedBy], references: [id])
  automatic      Boolean     @default(false)
  changedAt      DateTime    @default(now())

  @@index([orderId])
  @@index([changedBy])
}

// ─── MODELO: PAYMENT ────────────────────────────────────────

model Payment {
  id           String        @id @default(uuid())
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id])
  customerId   String
  customer     User          @relation("CustomerPayments", fields: [customerId], references: [id])
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  amount       Int
  currency     String        @default("MXN")
  providerData Json?
  reviewedBy   String?
  reviewer     User?         @relation("ReviewedPayments", fields: [reviewedBy], references: [id])
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([orderId])
  @@index([customerId])
  @@index([status])
}

// ─── MODELO: ADDRESS ─────────────────────────────────────────

model Address {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label            String    @db.VarChar(100)
  formattedAddress String
  details          String?
  lat              Decimal   @db.Decimal(10, 7)
  lng              Decimal   @db.Decimal(10, 7)
  isDefault        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  shipments Shipment[]

  @@index([userId])
}

// ─── MODELO: SHIPMENT ───────────────────────────────────────

model Shipment {
  id           String         @id @default(uuid())
  orderId      String         @unique
  order        Order          @relation(fields: [orderId], references: [id])
  addressId    String?
  address      Address?       @relation(fields: [addressId], references: [id])
  type         DeliveryType
  deliveryFee  Int            @default(0)
  carrier      String?        @db.VarChar(100)
  trackingCode String?        @db.VarChar(200)
  status       ShipmentStatus @default(PENDING)
  estimatedAt  DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  events ShipmentEvent[]

  @@index([status])
  @@index([type])
}

model ShipmentEvent {
  id         String         @id @default(uuid())
  shipmentId String
  shipment   Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  staffId    String?
  staff      User?          @relation("ShipmentEventStaff", fields: [staffId], references: [id])
  status     ShipmentStatus
  note       String?
  createdAt  DateTime       @default(now())

  @@index([shipmentId])
  @@index([shipmentId, createdAt])
}

// ─── MODELO: AUTH (OTP) ─────────────────────────────────────

model OTPCode {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  phone     String?
  email     String?
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, phone, verified])
  @@index([userId, email, verified])
  @@index([expiresAt])
}


// ─── MODELO: PROMOTION ENGINE ───────────────────────────────

model Promotion {
  id             String       @id @default(uuid())
  name           String
  description    String?
  couponCode     String?      @unique
  priority       Int          @default(0)
  stackable      Boolean      @default(false)
  isActive       Boolean      @default(true)
  startsAt       DateTime
  endsAt         DateTime?
  maxUsesPerUser Int?
  ruleOperator   RuleOperator @default(ALL)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // ─── DISPLAY / BANNER ─────────────────────
  imageUrl        String?
  colorPrimary    String?
  colorSecondary  String?
  badgeText       String?
  badgeColor      String?

  rules   PromotionRule[]
  actions PromotionAction[]
  usages  PromotionUsage[]

  @@index([isActive, startsAt, endsAt])
  @@index([couponCode])
  @@index([deletedAt, isActive, couponCode])
}

model PromotionRule {
  id          String             @id @default(uuid())
  promotionId String
  promotion   Promotion          @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  type        RuleType
  operator    ComparisonOperator
  value       String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([promotionId])
}

model PromotionAction {
  id                 String       @id @default(uuid())
  promotionId        String
  promotion          Promotion    @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  type               ActionType
  value              String
  maxDiscountInCents Int?
  target             ActionTarget
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([promotionId])
}

model PromotionUsage {
  id                    String    @id @default(uuid())
  promotionId           String
  promotion             Promotion @relation(fields: [promotionId], references: [id])
  userId                String
  user                  User      @relation(fields: [userId], references: [id])
  orderId               String
  order                 Order     @relation(fields: [orderId], references: [id])
  discountAmountInCents Int
  usedAt                DateTime  @default(now())

  @@unique([promotionId, orderId])
  @@index([userId])
  @@index([promotionId])
  @@index([userId, promotionId])
}
