{
  "name": "el-caprichito-backend",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "yarn prisma db seed",
    "db:reset": "prisma db push --force-reset && yarn db:seed",
    "db:test:push": "DATABASE_URL=postgresql://caprichito:caprichito123@localhost:5433/caprichito_test?schema=public prisma db push",
    "db:test:extensions": "docker exec caprichito-db-test psql -U caprichito -d caprichito_test -c 'CREATE EXTENSION IF NOT EXISTS pg_trgm;'",
    "pretest": "yarn db:test:push && yarn db:test:extensions",
    "pretest:run": "yarn db:test:push && yarn db:test:extensions"
  },
  "license": "MIT",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/oauth2": "^8.1.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-valibot": "^1.1.80",
    "ioredis": "^5.9.3",
    "node-cron": "^4.2.1",
    "pg": "^8.18.0",
    "socket.io": "^4.8.3",
    "twilio": "^5.12.2",
    "uuid": "^13.0.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^7.3.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
